GLUCOTRACKER_TOKEN=change-me
JWT_SECRET=change-me-to-at-least-32-random-characters
GLUCOTRACKER_DATABASE_URL=sqlite:///./data/glucotracker.sqlite3
GLUCOTRACKER_APP_TIMEZONE=Europe/Moscow
STORAGE_BACKEND=filesystem
PHOTO_STORAGE_DIR=./data/photos
PHOTO_MAX_SIZE_BYTES=12582912
LOG_LEVEL=INFO
GLUCOTRACKER_GEMINI_API_KEY=
GEMINI_API_KEY=
# Second Google AI Studio key (different project). Used when primary key hits
# daily/minute quota so photo estimate continues instead of hard-failing.
GEMINI_FALLBACK_API_KEY=
GEMINI_PROXY_URL=
GEMINI_MODEL_PHOTO=gemini-3.6-flash
GEMINI_MODEL=gemini-3.6-flash
GEMINI_CHEAP_MODEL=gemini-3.1-flash-lite-preview
GEMINI_FREE_TEST_MODEL=gemini-3.1-flash-lite-preview
GEMINI_FALLBACK_MODEL=gemini-3.1-flash-lite
GEMINI_FALLBACK_MODELS=gemini-3.5-flash,gemini-3.5-flash-lite
GEMINI_MAX_RETRIES_PER_MODEL=2
GEMINI_LOW_CONFIDENCE_RETRY_THRESHOLD=0.60
GEMINI_QUOTA_COOLDOWN_HOURS=30
GEMINI_OVERLOAD_COOLDOWN_HOURS=4
GEMINI_QUOTA_COOLDOWN_PATH=/media/megusto/storage/glucotracker/runtime/gemini-quota-cooldowns.json
# Final photo-estimate fallback after Gemini primary + GEMINI_FALLBACK_MODELS.
# Prefer SuperGrok browser login session (same as `grok` CLI):
#   grok login
#   # optional for systemd (ProtectHome): copy session for the service user
#   cp ~/.grok/auth.json /media/megusto/storage/glucotracker/runtime/grok-auth.json
# Or set a console key from https://console.x.ai :
XAI_API_KEY=
GROK_AUTH_JSON=
GROK_PHOTO_MODEL=grok-4.5
GROK_PHOTO_FALLBACK_ENABLED=true
NIGHTSCOUT_BASE_URL=http://127.0.0.1:1337
NIGHTSCOUT_API_SECRET=
NIGHTSCOUT_IMPORT_INTERVAL_SECONDS=300
ACTIVITY_LOG_DIR=./data/activity_logs
