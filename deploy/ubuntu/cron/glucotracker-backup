#!/bin/bash
set -euo pipefail

BACKUP_DIR=/var/backups/glucotracker
TIMESTAMP=$(date +%Y%m%d_%H%M%S)

mkdir -p "$BACKUP_DIR"

sudo -u postgres pg_dump glucotracker_prod \
  | gzip > "$BACKUP_DIR/db_${TIMESTAMP}.sql.gz"

tar czf "$BACKUP_DIR/photos_${TIMESTAMP}.tar.gz" -C /var/lib/glucotracker photos
tar czf "$BACKUP_DIR/config_${TIMESTAMP}.tar.gz" /etc/glucotracker /etc/caddy/Caddyfile

find "$BACKUP_DIR" -name "db_*.sql.gz" -mtime +7 -delete
find "$BACKUP_DIR" -name "photos_*.tar.gz" -mtime +7 -delete
find "$BACKUP_DIR" -name "config_*.tar.gz" -mtime +7 -delete
